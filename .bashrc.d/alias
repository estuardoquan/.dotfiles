# .bashrc.d/alias

alias ~="cd ~/"

alias ..="cd ../"

alias ...="cd ../../"

alias ....="cd ../../../"

alias c="clear"

alias l="ls -la -h --group-directories-first"

alias q="exit"

alias compose="docker compose"

alias composed="docker compose up -d"

alias compose_reset="docker compose down && docker compose up -d"

alias vi="nvim"

alias tf_apply="terraform apply -auto-approve"

alias tf_destroy="terraform apply -auto-approve -destroy"
