		// 	"title<.*google.*>": "¯ƒ░",
		// 	"chromium": "¯Øâ",
		// 	"class<kitty>": "¯»è",
		// 	"class<code>": "¯úÜ"
		// }
	},
	"hyprland/window": {
		"format": "{title}",
		"icon": true,
		"icon-size": 18,
		"separate-outputs": true
	},
	"pulseaudio": {
		"format": "{icon}",
		"format-bluetooth": "{icon}´èö",
		"format-muted": "´Çª",
		"format-icons": {
			"alsa_output.pci-0000_00_1f.3.analog-stereo": "¯î¡",
			"alsa_output.pci-0000_00_1f.3.analog-stereo-muted": "¯╗¿¯î¡",
			"headphone": "´ÇÑ",
			"hands-free": "´ûÉ",
			"headset": "´ûÉ",
			"phone": "´éò",
			"phone-muted": "¯┤ù",
			"portable": "´éò",
			"car": "´å╣",
			"default": ["´Çº", "´Ç¿"]
		},
		"scroll-step": 1,
		"on-click": "pavucontrol",
		"ignored-sinks": ["Easy Effects Sink"]
	}
}
